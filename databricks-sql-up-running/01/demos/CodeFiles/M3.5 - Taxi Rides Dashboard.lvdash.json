            "displayName": "Active"
          },
          {
            "name": "PermitLicenseNumber",
            "expr": "source.PermitLicenseNumber",
            "displayName": "Permit License Number"
          },
          {
            "name": "VehicleVinNumber",
            "expr": "source.VehicleVinNumber",
            "displayName": "Vehicle Vin Number"
          },
          {
            "name": "VehicleYear",
            "expr": "source.VehicleYear",
            "displayName": "Vehicle Year"
          },
          {
            "name": "VehicleType",
