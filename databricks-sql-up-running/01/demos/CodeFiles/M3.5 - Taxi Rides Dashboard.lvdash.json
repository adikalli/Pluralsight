{
  "datasets": [
    {
      "name": "b424145a",
      "displayName": "Taxi Rides with Pickup Details",
      "queryLines": [
        "SELECT tr.RideId,\r\n",
        "           tr.VendorId,\r\n",
        "           tr.PickupTime,\r\n",
        "           tr.DropTime,                     \r\n",
        "           tr.TripDistance,           \r\n",
        "           tr.TotalAmount,\r\n",
        "           DATEDIFF(MINUTE, tr.PickupTime, tr.DropTime)  AS TripTimeInMinutes,\r\n",
        "            \r\n",
        "           tz.Borough         AS PickupBorough,\r\n",
        "           tz.Zone            AS PickupZone,\r\n",
        "           tz.service_zone    AS PickupServiceZone\r\n",
        "\r\n",
        "    FROM taxicatalog.bronze.TaxiRides tr\r\n",
        "        \r\n",
        "        JOIN taxicatalog.bronze.TaxiZones tz     ON tr.PickupLocationId = tz.LocationID\r\n",
        "\r\n"
      ]
    },
    {
      "name": "c4f42ba2",
      "displayName": "cabs",
      "catalog": "taxicatalog",
      "config": {
        "version": "1.1",
        "source": "taxicatalog.bronze.cabs",
        "dimensions": [
          {
            "name": "CabNumber",
            "expr": "source.CabNumber",
            "displayName": "Cab Number"
          },
          {
