            "displayName": "Address"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "e2c98f48",
      "displayName": "Feedback Sentiments",
      "queryLines": [
        "SELECT Feedback\r\n",
        "\r\n",
        "      , ai_analyze_sentiment(feedback) AS Sentiment\r\n",
        "\r\n",
        "FROM taxicatalog.bronze.RidesFeedback"
      ]
    }
  ],
